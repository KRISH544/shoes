generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceType {
  RSS
  HTML
}

enum ReleaseStatus {
  NEW
  WATCHING
  RAFFLE_OPEN
  DROPPED
  MISSED
  ARCHIVED
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
}

enum NotificationStatus {
  QUEUED
  SENT
  SKIPPED
  FAILED
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  phone             String?
  emailEnabled      Boolean            @default(true)
  smsEnabled        Boolean            @default(false)
  pushEnabled       Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  keywords          Keyword[]
  preferences       AlertPreference?
  releaseMatches    ReleaseMatch[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  calendarReminders CalendarReminder[]
}

model AlertPreference {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  minLeadHours             Int      @default(0)
  sendOnRaffle             Boolean  @default(true)
  sendOnReleaseDateChange  Boolean  @default(true)
  calendarReminderMinutes  Int      @default(30)
  quietHoursStart          String?
  quietHoursEnd            String?
  timezone                 String   @default("Pacific/Auckland")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Keyword {
  id             String         @id @default(cuid())
  userId         String
  text           String
  normalized     String
  active         Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  releaseMatches ReleaseMatch[]

  @@unique([userId, normalized])
  @@index([active])
}

model Source {
  id            String    @id @default(cuid())
  name          String
  url           String    @unique
  type          SourceType
  active        Boolean   @default(true)
  retailer      String?
  region        String?
  notes         String?
  lastCheckedAt DateTime?
  lastStatus    String?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  releases      Release[]

  @@index([active])
}

model Release {
  id                String             @id @default(cuid())
  title             String
  slug              String
  sourceUrl         String             @unique
  productUrl        String?
  retailer          String?
  price             String?
  currency          String?
  releaseDate       DateTime?
  raffleUrl         String?
  imageUrl          String?
  notes             String?
  status            ReleaseStatus      @default(NEW)
  sourceId          String?
  source            Source?            @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  releaseMatches    ReleaseMatch[]
  notifications     Notification[]
  calendarReminders CalendarReminder[]
  firstSeenAt       DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([releaseDate])
  @@index([status])
}

model ReleaseMatch {
  id          String   @id @default(cuid())
  userId      String
  releaseId   String
  keywordId   String?
  matchedText String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  release     Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  keyword     Keyword? @relation(fields: [keywordId], references: [id], onDelete: SetNull)

  @@unique([userId, releaseId, matchedText])
  @@index([createdAt])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  releaseId String
  channel   NotificationChannel
  status    NotificationStatus  @default(QUEUED)
  error     String?
  sentAt    DateTime?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  release   Release             @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@unique([userId, releaseId, channel])
  @@index([status])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh     String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CalendarReminder {
  id              String   @id @default(cuid())
  userId          String
  releaseId       String
  reminderMinutes Int      @default(30)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  release         Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@unique([userId, releaseId])
}
